<div class="qblock"><div class="qnum">DS Q1</div><div><div class="qtitle">Student Weight Analysis using R</div><div class="qsub">Min/Max · Percentage between 60-70 kg · Frequency Graph · Outlier Detection</div></div><span class="mbadge m10">10 Marks</span></div>
<div class="sec">📖 Dataset</div>
<div class="understand"><div class="ul">Given data</div><p>Weights of 50 students in kilograms. Tasks: (i) min/max, (ii) % students between 60-70kg, (iii) frequency distribution graph, (iv) find outlier.</p></div>
<div class="ans-card"><div class="ans-head"><span>R Program — Complete Student Weight Analysis</span></div>
<div class="ans-body">
<div class="code"># MCSL-229 Data Science Lab - Q1
# Student Weight Analysis using R
# Dataset: 50 student weights in kg

# Step 1: Enter the dataset
weights <- c(42, 45, 48, 50, 47, 46, 44, 49, 51, 43,
             52, 55, 54, 53, 56, 58, 57, 54, 55, 52,
             46, 48, 49, 47, 45, 44, 46, 48, 50, 47,
             60, 62, 89, 59, 58, 57, 60, 61, 63, 59,
             50, 52, 51, 49, 48, 47, 50, 52, 53, 51)

cat("Dataset loaded: 50 student weights\n\n")

# ─────────────────────────────────────────────────
# (i) Find Minimum and Maximum Weight   [2 Marks]
# ─────────────────────────────────────────────────
cat("(i) MINIMUM AND MAXIMUM WEIGHT:\n")
cat("    Minimum Weight:", min(weights), "kg\n")
cat("    Maximum Weight:", max(weights), "kg\n")
cat("    Range          :", max(weights) - min(weights), "kg\n\n")

# ─────────────────────────────────────────────────
# (ii) % Students between 60 and 70 kg  [2 Marks]
# ─────────────────────────────────────────────────
cat("(ii) PERCENTAGE OF STUDENTS (60 to 70 kg):\n")
count_60_70 <- sum(weights >= 60 & weights <= 70)
percentage  <- (count_60_70 / length(weights)) * 100
cat("    Number of students (60-70 kg):", count_60_70, "\n")
cat("    Total students:", length(weights), "\n")
cat("    Percentage:", round(percentage, 2), "%\n\n")

# ─────────────────────────────────────────────────
# (iii) Frequency Distribution Graph    [4 Marks]
# ─────────────────────────────────────────────────
cat("(iii) FREQUENCY DISTRIBUTION:\n")

# Create frequency table using breaks
breaks    <- c(40, 50, 60, 70, 80, 90)
freq_table <- cut(weights, breaks = breaks, right = FALSE,
                  labels = c("40-49","50-59","60-69","70-79","80-89"))
freq_count <- table(freq_table)
cat("Frequency Table:\n")
print(freq_count)

# Draw histogram
hist(weights,
     breaks   = breaks,
     col      = "steelblue",
     border   = "white",
     main     = "Frequency Distribution of Student Weights",
     xlab     = "Weight (kg)",
     ylab     = "Number of Students",
     xlim     = c(40, 95),
     ylim     = c(0, 25))

# Add labels on bars
freq_values <- as.vector(freq_count)
bar_centers <- c(45, 55, 65, 75, 85)
text(bar_centers, freq_values + 0.5, labels = freq_values, cex = 1.1)
cat("\nHistogram plotted successfully.\n\n")

# ─────────────────────────────────────────────────
# (iv) Find the Outlier                 [2 Marks]
# ─────────────────────────────────────────────────
cat("(iv) OUTLIER DETECTION (IQR Method):\n")
Q1_val <- quantile(weights, 0.25)
Q3_val <- quantile(weights, 0.75)
IQR_val <- Q3_val - Q1_val

lower_bound <- Q1_val - 1.5 * IQR_val
upper_bound <- Q3_val + 1.5 * IQR_val

cat("    Q1 (25th percentile):", Q1_val, "\n")
cat("    Q3 (75th percentile):", Q3_val, "\n")
cat("    IQR (Q3 - Q1)       :", IQR_val, "\n")
cat("    Lower Bound (Q1 - 1.5×IQR):", lower_bound, "\n")
cat("    Upper Bound (Q3 + 1.5×IQR):", upper_bound, "\n")

outliers <- weights[weights < lower_bound | weights > upper_bound]
cat("\n    OUTLIERS DETECTED:", outliers, "\n")
cat("    (These values fall outside the normal range)\n\n")

# Draw boxplot to visualise outlier
boxplot(weights,
        main = "Boxplot of Student Weights (Outlier Detection)",
        ylab = "Weight (kg)",
        col  = "lightblue",
        border = "darkblue")
points(outliers, col = "red", pch = 16, cex = 1.5)
text(1.15, outliers, labels = paste("Outlier:", outliers), col = "red")

cat("Boxplot plotted with outlier marked in red.\n")</div>
