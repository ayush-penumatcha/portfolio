        th    { background: #4285f4; color: white; padding: 8px 14px; }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;h1&gt;Matrix Transpose Calculator&lt;/h1&gt;
    &lt;h3&gt;MCSL-229 - Cloud &amp; Data Science Lab&lt;/h3&gt;
    &lt;form method="POST"&gt;
        &lt;label&gt;Enter matrix rows (comma separated, one row per line):&lt;/label&gt;&lt;br&gt;
        &lt;textarea name="matrix" rows="5" cols="30" 
                  placeholder="1,2,3&#10;4,5,6&#10;7,8,9"&gt;{{ matrix_input }}&lt;/textarea&gt;
        &lt;br&gt;&lt;br&gt;
        &lt;button type="submit"&gt;Compute Transpose&lt;/button&gt;
    &lt;/form&gt;
    {% if original %}
    &lt;h3&gt;Original Matrix:&lt;/h3&gt;
    &lt;table&gt;
        {% for row in original %}
        &lt;tr&gt;{% for val in row %}&lt;td&gt;{{ val }}&lt;/td&gt;{% endfor %}&lt;/tr&gt;
        {% endfor %}
    &lt;/table&gt;
    &lt;h3&gt;Transposed Matrix:&lt;/h3&gt;
    &lt;table&gt;
        {% for row in transposed %}
        &lt;tr&gt;{% for val in row %}&lt;td&gt;{{ val }}&lt;/td&gt;{% endfor %}&lt;/tr&gt;
        {% endfor %}
    &lt;/table&gt;
    {% endif %}
&lt;/body&gt;
&lt;/html&gt;
"""

@app.route('/', methods=['GET', 'POST'])
def index():
    original = None
    transposed = None
    matrix_input = ""

    if request.method == 'POST':
        matrix_input = request.form.get('matrix', '')
        try:
            # Parse input matrix
            rows = matrix_input.strip().split('\n')
            original = [[int(x) for x in row.split(',')] for row in rows]
            # Compute transpose
            transposed = [list(row) for row in zip(*original)]
        except Exception as e:
            matrix_input = f"Error: {e}"

    return render_template_string(HTML_TEMPLATE,
                                  original=original,
                                  transposed=transposed,
                                  matrix_input=matrix_input)

if __name__ == '__main__':
    app.run(debug=True)</div>

