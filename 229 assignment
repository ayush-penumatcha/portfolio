<!-- DS Q2: Linear Regression -->
<div id="dsq2">
<div class="qblock"><div class="qnum">DS Q2</div><div><div class="qtitle">Linear Regression — Fertiliser vs Crop Yield</div><div class="qsub">Fit regression line · Predict yield at 75 kg/acre fertiliser · R programming</div></div><span class="mbadge m10">10 Marks</span></div>
<div class="sec">📖 Dataset</div>
<div class="understand"><div class="ul">Given data</div><p>10 farms with fertiliser use (kg/acre) and crop yield (quintals/acre). Fit a linear regression model to predict yield, and specifically predict the yield when fertiliser = 75 kg/acre.</p></div>
<div class="ans-card"><div class="ans-head"><span>R Program — Linear Regression on Crop Yield Data</span></div>
<div class="ans-body">
<div class="code"># MCSL-229 Data Science Lab - Q2
# Linear Regression: Fertiliser Use vs Crop Yield
# Goal: Predict yield when fertiliser = 75 kg/acre

# Step 1: Enter the Dataset
fertiliser <- c(40, 45, 50, 55, 60, 48, 65, 58, 42, 70)
yield      <- c(18, 20, 22, 24, 20, 21, 29, 25, 19, 32)

# Create data frame
farm_data <- data.frame(
  Farm       = 1:10,
  Fertiliser = fertiliser,
  Yield      = yield
)

cat("Agricultural Dataset:\n")
print(farm_data)
cat("\n")

# Step 2: Exploratory Analysis
cat("Summary Statistics:\n")
cat("  Fertiliser — Mean:", mean(fertiliser), "kg/acre\n")
cat("  Yield      — Mean:", mean(yield), "quintals/acre\n")
cat("  Correlation (r)  :", round(cor(fertiliser, yield), 4), "\n\n")

# Step 3: Fit Linear Regression Model
# Model: Yield = b0 + b1 × Fertiliser
model <- lm(yield ~ fertiliser)

cat("Linear Regression Results:\n")
print(summary(model))

# Extract coefficients
b0 <- coef(model)[1]   # Intercept
b1 <- coef(model)[2]   # Slope

cat("\nRegression Equation:\n")
cat(sprintf("  Yield = %.4f + %.4f × Fertiliser\n\n", b0, b1))

# Step 4: Assess Model Quality
r_squared <- summary(model)$r.squared
cat(sprintf("R² (Coefficient of Determination): %.4f\n", r_squared))
cat(sprintf("Interpretation: %.1f%% of variation in yield is\n", r_squared * 100))
cat("explained by fertiliser use.\n\n")

# Step 5: Predict yield for 75 kg/acre fertiliser
new_data    <- data.frame(fertiliser = 75)
prediction  <- predict(model, new_data, interval = "confidence")

cat("PREDICTION FOR 75 kg/acre FERTILISER:\n")
cat(sprintf("  Predicted Yield = %.2f quintals/acre\n", prediction[1]))
cat(sprintf("  95%% Confidence Interval: [%.2f, %.2f]\n\n",
            prediction[2], prediction[3]))

# Step 6: Plot regression line
plot(fertiliser, yield,
     main  = "Fertiliser vs Crop Yield with Regression Line",
     xlab  = "Fertiliser Used (kg/acre)",
     ylab  = "Crop Yield (quintals/acre)",
     pch   = 16, col = "darkblue", cex = 1.3,
     xlim  = c(38, 80), ylim = c(15, 38))

# Add regression line
abline(model, col = "red", lwd = 2)

# Mark the prediction point
points(75, prediction[1], col = "green", pch = 18, cex = 2)
text(75, prediction[1] + 0.8,
     labels = paste("Pred:", round(prediction[1], 2)),
     col = "darkgreen", cex = 0.9)

# Add data point labels
text(fertiliser, yield - 0.7, labels = paste("F", 1:10, sep=""),
     cex = 0.7, col = "gray40")

legend("topleft",
       legend = c("Actual Data", "Regression Line", "Prediction at 75kg"),
       col    = c("darkblue", "red", "green"),
       pch    = c(16, NA, 18), lty = c(NA, 1, NA))

cat("Regression plot created successfully.\n")</div>
