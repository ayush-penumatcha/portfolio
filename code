function animVWire(wid){ return new Promise(function(res){ var b=$id('vb-'+wid),f=$id('vf-'+wid); if(!b||!f){res();return;} var p=-5; (function go(){p+=3;b.style.top=p+'%';b.style.opacity=(p>-3&&p<102)?'1':'0'; p<106?requestAnimationFrame(go):(b.style.opacity='0',f.style.height='100%',res()); })(); }); }

function fillNode(nid,ms){ return new Promise(function(res){ var f=$id('fill-'+nid);if(!f){res();return;} var p=0,tick=35,per=100/(ms/tick); var t=setInterval(function(){ if(st.isPaused){clearInterval(t);new Promise(function(r){st.pauseDone=r;}).then(function(){fillFrom(nid,p,ms*(1-p/100)).then(res);});return;} p=Math.min(p+per,100);f.style.width=p+'%'; if(p>=100){clearInterval(t);res();} },tick); }); }
function fillFrom(nid,from,ms){ return new Promise(function(res){ var f=$id('fill-'+nid);if(!f){res();return;} var p=from,tick=35,per=(100-from)/(ms/tick); var t=setInterval(function(){p=Math.min(p+per,100);f.style.width=p+'%';if(p>=100){clearInterval(t);res();}},tick); }); }

async function haltIfPaused(){
