  if(intent==='how_to'){
    w.appendChild(card({icon:'📖',accent:C.sky,bg:C.skyF,title:'Workflow Docs'+modeNote,body:'Three stages:\n\n**Stage 1 (02:00)** — File ingestion from vendor SFTP.\n**Stage 2 (02:15)** — Transform + validate. Most failures happen here.\n**Stage 3 (02:45)** — Report generation and dispatch.'}));
    w.appendChild(card({icon:'💡',accent:C.mint,bg:C.mintF,title:'Key Note',body:'Pre-validation before Stage 2 is mandatory per SOP. Skipping it is the most common cause of silent failures.\n[[OPS-SOP-007 — Citi Workflow Guide]]'}));
    return w;
  }
  if(intent==='dev_help'){
    w.appendChild(card({icon:'💻',accent:C.vio,bg:C.vioF,title:'Null Check Issue',body:'**Null pointer** before object initialisation — upstream returned empty and nothing checked for it.\n\n`if (obj != null) { obj.method(); }`\n\nCheck the data contract from the previous pipeline stage.'}));
    w.appendChild(card({icon:'🔍',accent:C.sky,bg:C.skyF,title:'Context'+modeNote,body:'==3 identical exceptions== in the last 7 days — all during low-data runs where upstream feed returned empty.'}));
    w.appendChild(card({icon:'📄',accent:C.mint,bg:C.mintF,title:'Docs',body:'[[Null Safety Guidelines — Dev Wiki]]\n[[Error Handling Patterns — Runbook]]'}));
    return w;
  }
  // general_ops
  w.appendChild(card({icon:'🔍',accent:C.sky,bg:C.skyF,title:'Full Scan'+modeNote,body:'All active connectors checked. No critical issues in the last hour, ==1 open P2== in Remedy, ==2 SOP pages== matching your keywords.'}));
  w.appendChild(card({icon:'💡',accent:C.mint,bg:C.mintF,title:'Tip',body:'Mention a specific job name, ticket number, or error message for a more targeted answer.'}));
  return w;
}

// log panel heplers
const logLevels={INFO:{bg:C.skyF,txt:C.sky},OK:{bg:C.mintF,txt:C.mint},FETCH:{bg:C.vioF,txt:C.vio},WARN:{bg:C.ambF,txt:C.amb},ERR:{bg:C.redF,txt:C.red}};

function writeLog(lvl,msg,delay){
  delay=delay||0;
  return new Promise(function(res){
    setTimeout(function(){
      st.logN++;
      var cnt=$id('log-count'); if(cnt)cnt.textContent=st.logN+(st.logN===1?' event':' events');
      var n=new Date(),ts=[n.getHours(),n.getMinutes(),n.getSeconds()].map(x=>String(x).padStart(2,'0')).join(':');
      var lc=logLevels[lvl]||logLevels.INFO;
      var row=mk('div',{style:{display:'grid',gridTemplateColumns:'64px 50px 1fr',alignItems:'baseline',padding:'4px 18px',fontFamily:C.mono,fontSize:'11.5px',lineHeight:'1.5',borderBottom:'1px solid rgba(255,255,255,.025)',opacity:'0',transform:'translateY(10px)',transition:'background .15s,opacity .22s,transform .22s',cursor:'default'}});
      row.addEventListener('mouseover',()=>row.style.background='rgba(99,179,237,.03)');
      row.addEventListener('mouseout', ()=>row.style.background='transparent');
      var mEl=mk('span',{style:{color:C.tx2,paddingLeft:'10px',fontSize:'11.5px'}}); mEl.innerHTML=msg;
      row.appendChild(mk('span',{text:ts,style:{color:C.tx3,fontSize:'10.5px'}}));
      row.appendChild(mk('span',{text:lvl,style:{fontSize:'9.5px',fontWeight:'700',padding:'1px 5px',borderRadius:'3px',background:lc.bg,color:lc.txt}}));
      row.appendChild(mEl);
      var ll=$id('log-strip');
      if(ll){ll.appendChild(row);requestAnimationFrame(()=>{row.style.opacity='1';row.style.transform='translateY(0)';});ll.scrollTop=ll.scrollHeight;}
      res();
    },delay);
  });
}
function clearLog(){var l=$id('log-strip');if(l)l.innerHTML='';st.logN=0;var c=$id('log-count');if(c)c.textContent='0 events';}

// chat helpers
function msgGroup(role){
  var g=mk('div',{cls:role==='user'?'msg-user':'msg-bot'});
  var ts=new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
  g.appendChild(mk('div',{text:role==='user'?'You · '+ts:'WamSave · '+ts,style:{fontSize:'11px',fontFamily:C.mono,color:C.tx3,padding:'0 4px'}}));
  var bub=mk('div',{cls:'bubble'});
  role==='user'
    ?sty(bub,{background:'linear-gradient(140deg,rgba(99,179,237,.18),rgba(99,179,237,.07))',border:'1px solid rgba(99,179,237,.22)',color:'#d0e8f9',borderBottomRightRadius:'3px'})
    :sty(bub,{background:C.card,border:'1px solid '+C.bdr,color:C.tx,borderBottomLeftRadius:'3px'});
  g.appendChild(bub); return g;
}
function pushMsg(role,content){
  var list=$id('chat-msgs'),g=msgGroup(role),bub=g.querySelector('.bubble');
  if(role==='user')bub.textContent=content;
  else typeof content==='string'?(bub.innerHTML=content):bub.appendChild(content);
  list.appendChild(g); list.scrollTop=list.scrollHeight;
}
function showDots(){
  var list=$id('chat-msgs');
  var row=mk('div',{id:'dots-row',cls:'msg-bot'});
  var bub=mk('div',{style:{display:'flex',gap:'5px',alignItems:'center',padding:'12px 15px',background:C.card,border:'1px solid '+C.bdr,borderRadius:'14px',borderBottomLeftRadius:'3px',width:'fit-content'}});
  for(var i=0;i<3;i++) bub.appendChild(mk('div',{style:{width:'6px',height:'6px',borderRadius:'50%',background:C.tx3,animation:'dot-bop 1.1s ease-in-out '+(i*.18)+'s infinite'}}));
  row.appendChild(bub); list.appendChild(row); list.scrollTop=list.scrollHeight;
}
function hideDots(){var r=$id('dots-row');if(r)r.parentNode.removeChild(r);}

var busy=false;
async function sendMessage(){
  var inp=$id('chat-input'),q=inp.value.trim();
  if(!q||busy)return;
  busy=true; inp.value='';
  var btn=$id('btn-send-main'); if(btn)btn.disabled=true;
  pushMsg('user',q); showDots();
  var intent=guessIntent(q);

  if(intent==='chitchat'){
    await sleep(700); hideDots();
    pushMsg('bot',buildReply(intent,q));
    $id('idle-placeholder').style.display='flex';
    var nc=$id('nodes-container'); if(nc)nc.style.display='none';
  } else {
    await runPipeline(q,intent); hideDots();
    pushMsg('bot',buildReply(intent,q));
  }
  await sleep(300); busy=false; if(btn)btn.disabled=false;
}

// topbar
function buildTopbar(){
  var bar=$id('topbar');
  bar.appendChild(mk('div',{html:'Wam<span style="color:'+C.sky+'">Save</span>',style:{fontFamily:C.brand,fontSize:'21px',fontWeight:'800',letterSpacing:'-.5px',color:'#fff'}}));
  bar.appendChild(mk('div',{style:{width:'1px',height:'22px',background:C.bdr}}));

  let pill=mk('div',{style:{display:'flex',alignItems:'center',gap:'6px',fontFamily:C.mono,fontSize:'11px',color:C.mint,background:C.mintF,border:'1px solid rgba(52,211,153,.25)',padding:'3px 10px',borderRadius:'20px'}});
  pill.appendChild(mk('div',{style:{width:'6px',height:'6px',borderRadius:'50%',background:C.mint,boxShadow:'0 0 8px '+C.mint,animation:'pulse 2s ease-in-out infinite'}}));
  pill.appendChild(mk('span',{text:'Connected'}));
  bar.appendChild(pill);

  // mode label
  var modeLabel=mk('div',{id:'mode-label',style:{fontFamily:C.mono,fontSize:'10px',color:C.tx3,letterSpacing:'.3px'}});
  bar.appendChild(modeLabel); bar.appendChild(mk('div',{style:{flex:'1'}}));
  updateModeLabel();

  var btnPause=mk('button',{id:'btn-pause-main',style:{display:'flex',alignItems:'center',gap:'6px',fontFamily:C.mono,fontSize:'10px',padding:'5px 12px',borderRadius:'6px',border:'1px solid rgba(255,255,255,.08)',color:C.tx3,background:C.card,cursor:'pointer',transition:'all .18s',letterSpacing:'.3px'}});
  function syncPauseBtn(){
    if(!st.isRunning){btnPause.innerHTML=svg('pause',11,C.tx3)+' <span>Pause</span>';sty(btnPause,{color:C.tx3,background:C.card,border:'1px solid rgba(255,255,255,.08)',animation:'none',boxShadow:'none'});}
    else if(st.isPaused){btnPause.innerHTML=svg('play',11,C.amb)+' <span style="color:'+C.amb+'">Resume</span>';sty(btnPause,{color:C.amb,background:C.ambF,border:'1px solid rgba(251,191,36,.4)',animation:'glow-amber .9s ease-in-out infinite',boxShadow:'none'});}
    else{btnPause.innerHTML=svg('pause',11,C.sky)+' <span style="color:'+C.sky+'">Pause</span>';sty(btnPause,{color:C.sky,background:C.skyF,border:'1px solid rgba(99,179,237,.3)',animation:'none',boxShadow:'none'});}
  }
  btnPause.addEventListener('click',function(){
    if(!st.isRunning)return;
    st.isPaused=!st.isPaused;
    if(!st.isPaused&&st.pauseDone){st.pauseDone();st.pauseDone=null;}
    syncPauseBtn();
    var led=$id('run-led');
    if(led)st.isPaused?sty(led,{background:C.amb,boxShadow:'0 0 8px '+C.amb,animation:'none'}):sty(led,{background:C.mint,boxShadow:'0 0 8px '+C.mint,animation:'pulse 1s ease-in-out infinite'});
  });
  window._syncPauseBtn=syncPauseBtn;
  bar.appendChild(btnPause);

  var clock=mk('div',{id:'top-clock',style:{fontFamily:C.mono,fontSize:'11px',color:C.tx3,letterSpacing:'.5px'}});
  bar.appendChild(clock);
  (function tick(){var n=new Date();clock.textContent=[n.getHours(),n.getMinutes(),n.getSeconds()].map(x=>String(x).padStart(2,'0')).join(':');setTimeout(tick,1000);})();
}

function updateModeLabel(){
  var lbl=$id('mode-label'); if(!lbl)return;
  var mc=CONNECTORS.filter(c=>c.mode==='mcp').length;
  var fb=CONNECTORS.filter(c=>c.mode==='fallback').length;
  var off=CONNECTORS.filter(c=>c.mode==='off').length;
  var parts=[];
  if(mc)parts.push(mc+' MCP');
  if(fb)parts.push(fb+' fallback');
  if(off)parts.push(off+' off');
  lbl.textContent=parts.join(' · ');
}

// chat panel build
function buildChatPanel(){
  var hdr=$id('chat-hdr');
  var hl=mk('div');
  hl.appendChild(mk('div',{text:'WamSave Assistant',style:{fontSize:'15px',fontWeight:'600',color:C.tx}}));
  hl.appendChild(mk('div',{text:'Ask about jobs, code, systems, docs, or anything',style:{fontSize:'12px',color:C.tx3,marginTop:'2px'}}));
  hdr.appendChild(hl);
  hdr.appendChild(mk('div',{text:'WS-NLP',style:{fontFamily:C.mono,fontSize:'10px',padding:'3px 9px',borderRadius:'4px',background:C.skyF,border:'1px solid rgba(99,179,237,.3)',color:C.sky}}));

  // welcome card
  var msgs=$id('chat-msgs');
  var wc=mk('div',{style:{background:C.lift,border:'1px solid '+C.bdr,borderRadius:'12px',padding:'18px',display:'flex',flexDirection:'column',gap:'10px'}});
  wc.appendChild(mk('div',{text:'Hey there! 👋',style:{fontFamily:C.brand,fontSize:'16px',fontWeight:'700'}}));
  wc.appendChild(mk('div',{text:'Ask me about jobs, incidents, code, SOPs, or anything ops-related. The connector config on the right controls whether each system uses its API or a fallback method.',style:{fontSize:'13.5px',color:C.tx2,lineHeight:'1.6'}}));
  var tags=mk('div',{style:{display:'flex',flexWrap:'wrap',gap:'6px',marginTop:'2px'}});
  ['⚡ Control-M','🔍 Splunk','🎫 Remedy','📄 Confluence','🗂 Jira'].forEach(function(t){
    tags.appendChild(mk('span',{text:t,style:{fontSize:'11.5px',fontFamily:C.mono,padding:'3px 10px',borderRadius:'20px',border:'1px solid '+C.bdr,color:C.tx3,background:C.card}}));
  });
  wc.appendChild(tags);
  var wg=msgGroup('bot'); wg.querySelector('.bubble').appendChild(wc);
  msgs.appendChild(wg);

  // input
  var foot=$id('chat-foot');
  var chips=mk('div',{style:{display:'flex',flexWrap:'wrap',gap:'6px'}});
  ['NAV job failed today?','Show P1 incidents','Log error to Jira','How does Citi workflow run?','Null pointer in deploy pipeline','Good morning!'].forEach(function(p){
    var c=mk('button',{text:p,style:{fontSize:'11.5px',fontFamily:C.mono,padding:'5px 11px',borderRadius:'20px',border:'1px solid '+C.bdr,color:C.tx3,background:C.card,cursor:'pointer',transition:'all .18s',whiteSpace:'nowrap'}});
    c.addEventListener('mouseover',()=>sty(c,{borderColor:'rgba(99,179,237,.35)',color:C.sky,background:C.skyF}));
    c.addEventListener('mouseout', ()=>sty(c,{borderColor:C.bdr,color:C.tx3,background:C.card}));
    c.addEventListener('click',()=>{$id('chat-input').value=p;sendMessage();});
    chips.appendChild(c);
  });
  foot.appendChild(chips);

  var row=mk('div',{style:{display:'flex',gap:'8px',alignItems:'flex-end'}});
  var ta=mk('textarea',{id:'chat-input',attrs:{placeholder:'Ask anything…',rows:'1'},style:{flex:'1',background:C.card,border:'1px solid '+C.bdr,borderRadius:'10px',padding:'11px 14px',color:C.tx,fontFamily:C.sans,fontSize:'14px',resize:'none',outline:'none',height:'46px',lineHeight:'1.5',transition:'border-color .2s,box-shadow .2s'}});
  ta.addEventListener('focus',()=>sty(ta,{borderColor:'rgba(99,179,237,.4)',boxShadow:'0 0 0 3px rgba(99,179,237,.06)'}));
  ta.addEventListener('blur', ()=>sty(ta,{borderColor:C.bdr,boxShadow:'none'}));
  ta.addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}});

  var bs=mk('button',{id:'btn-send-main',html:svg('arrow',18,'#fff'),style:{width:'46px',height:'46px',borderRadius:'10px',flexShrink:'0',background:'linear-gradient(135deg,'+C.sky+',#3b82f6)',border:'none',cursor:'pointer',display:'flex',alignItems:'center',justifyContent:'center',transition:'transform .15s,box-shadow .2s'}});
  bs.addEventListener('mouseover',()=>sty(bs,{transform:'translateY(-1px)',boxShadow:'0 4px 18px rgba(99,179,237,.3)'}));
  bs.addEventListener('mouseout', ()=>sty(bs,{transform:'none',boxShadow:'none'}));
  bs.addEventListener('click',sendMessage);
  row.appendChild(ta); row.appendChild(bs); foot.appendChild(row);
}

// log panel header
function buildLogHeader(){
  var hdr=$id('log-header');
  hdr.appendChild(mk('div',{id:'log-led',style:{width:'7px',height:'7px',borderRadius:'50%',background:C.tx3,transition:'background .3s,box-shadow .3s'}}));
  hdr.appendChild(mk('div',{text:'Execution Log',style:{fontFamily:C.mono,fontSize:'10px',letterSpacing:'2px',color:C.tx3,textTransform:'uppercase'}}));
  hdr.appendChild(mk('div',{id:'log-count',text:'0 events',style:{marginLeft:'auto',fontFamily:C.mono,fontSize:'10px',color:C.tx3}}));
  // placeholder
  var ph=mk('div',{style:{display:'grid',gridTemplateColumns:'64px 50px 1fr',alignItems:'baseline',padding:'4px 18px',fontFamily:C.mono,fontSize:'11.5px',lineHeight:'1.5',opacity:'.28'}});
  ph.innerHTML='<span style="color:'+C.tx3+';font-size:10.5px">--:--:--</span><span style="font-size:9.5px;font-weight:700;padding:1px 5px;border-radius:3px;background:'+C.skyF+';color:'+C.sky+'">INFO</span><span style="color:'+C.tx2+';padding-left:10px">Waiting for query…</span>';
  $id('log-strip').appendChild(ph);
}

// piepline strip
function buildPipeStrip(){
  var strip=$id('pipe-strip');
  strip.appendChild(mk('div',{id:'run-led',style:{width:'7px',height:'7px',borderRadius:'50%',background:C.tx3,flexShrink:'0',transition:'background .3s,box-shadow .3s'}}));
  strip.appendChild(mk('div',{text:'Pipeline',style:{fontFamily:C.mono,fontSize:'11px',letterSpacing:'2px',color:C.tx3,textTransform:'uppercase'}}));
  strip.appendChild(mk('div',{style:{flex:'1'}}));
  strip.appendChild(mk('div',{id:'elapsed-timer',text:'—',style:{fontFamily:C.mono,fontSize:'11px',color:C.tx3}}));
}

// drag resize
function setupResize(){
  var colEl=$id('col-resizer-handle'), rowEl=$id('log-resizer-handle');
  var cD=false,cX=0,cW=0, rD=false,rY=0,rH=0;
  colEl.addEventListener('mousedown',function(e){cD=true;cX=e.clientX;cW=$id('chat-main').offsetWidth;colEl.classList.add('active');document.body.style.cursor='col-resize';document.body.style.userSelect='none';});
  rowEl.addEventListener('mousedown',function(e){rD=true;rY=e.clientY;rH=$id('log-area').offsetHeight;rowEl.classList.add('active');document.body.style.cursor='row-resize';document.body.style.userSelect='none';});
  document.addEventListener('mousemove',function(e){
    if(cD){let w=Math.max(240,Math.min(window.innerWidth*.65,cW+(e.clientX-cX)));st.chatW=w;sty($id('chat-main'),{width:w+'px'});}
    if(rD){let h=Math.max(60,Math.min(window.innerHeight*.6,rH+(rY-e.clientY)));st.logH=h;sty($id('log-area'),{height:h+'px'});}
  });
  document.addEventListener('mouseup',function(){
    if(cD){cD=false;colEl.classList.remove('active');document.body.style.cursor='';document.body.style.userSelect='';}
    if(rD){rD=false;rowEl.classList.remove('active');document.body.style.cursor='';document.body.style.userSelect='';}
  });
}

window.addEventListener('resize',function(){
  var mW=window.innerWidth*.65; if(st.chatW>mW){st.chatW=mW;var c=$id('chat-main');if(c)c.style.width=mW+'px';}
  var mH=window.innerHeight*.6; if(st.logH>mH){st.logH=mH;var l=$id('log-area');if(l)l.style.height=mH+'px';}
});

// init
function init(){
  buildTopbar();
  buildChatPanel();
  buildPipeStrip();
  buildLogHeader();
  buildConfigPanel();
  rebuildPipeline();
  setupResize();
  console.log('WamSave v2.3 loaded - built in 2 days');
}

setTimeout(init,0);
</script>
