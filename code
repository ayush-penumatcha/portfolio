function startTimer(){_tStart=Date.now();var t=$id('elapsed-timer');if(t)t.textContent='0.0s';_tRef=setInterval(()=>{var d=$id('elapsed-timer');if(d)d.textContent=((Date.now()-_tStart)/1000).toFixed(1)+'s';},100);}
function stopTimer(){if(_tRef){clearInterval(_tRef);_tRef=null;}var e=((Date.now()-_tStart)/1000).toFixed(1);var d=$id('elapsed-timer');if(d)d.textContent=e+'s ✓';return e;}

// main pipeline runner
async function runPipeline(query, intent) {
  $id('idle-placeholder').style.display='none';
  $id('nodes-container').style.display='flex';
  resetNodes(); clearLog();

  var activeKeys = intentConnectors[intent]||intentConnectors.general_ops;
  var graph = buildPipelineGraph();

  var runLed=$id('run-led'),logLed=$id('log-led');
  if(runLed)sty(runLed,{background:C.mint,boxShadow:'0 0 8px '+C.mint,animation:'pulse 1s ease-in-out infinite'});
  if(logLed)sty(logLed,{background:C.mint,boxShadow:'0 0 8px '+C.mint,animation:'pulse 1s ease-in-out infinite'});

  st.isRunning=true; window._syncPauseBtn&&window._syncPauseBtn(); startTimer();

  writeLog('INFO','Query: <strong>"'+query.substring(0,52)+(query.length>52?'…':'')+'"</strong>');
  writeLog('INFO','Mode: <span style="color:'+C.sky+'">MIXED</span>  Intent: <span style="color:'+C.mint+'">'+intent+'</span>',60);

  // section 0 — always the same: user → intent → router
  var s0=graph.sections[0];
  nodeState('node-user','active');
  writeLog('INFO','Input tokenised — '+query.trim().split(/\s+/).length+' tokens',50);
  await fillNode('node-user',380); nodeState('node-user','done');
  await animHWire(s0.wires[0]); await haltIfPaused();

  nodeState('node-intent','active');
  writeLog('FETCH','NLP classifier running…',50);
  await fillNode('node-intent',460); nodeState('node-intent','done');
  writeLog('OK','Intent → <span style="color:'+C.sky+'">'+intent+'</span>',70);
  await animHWire(s0.wires[1]); await haltIfPaused();

  nodeState('node-router','active');
  // figure out which connectors are active for this intent
  var activeMcp=CONNECTORS.filter(c=>c.mode==='mcp'&&activeKeys.includes(c.key));
  var activeFb =CONNECTORS.filter(c=>c.mode==='fallback'&&activeKeys.includes(c.key));
  writeLog('INFO','Routing: <span style="color:'+C.sky+'">'+(activeMcp.length)+' MCP</span> + <span style="color:'+C.amb+'">'+(activeFb.length)+' fallback</span> connectors',40);
  await fillNode('node-router',380); nodeState('node-router','done');
  await animVWire('vw-0'); await haltIfPaused();

  // activate nodes, fire wires
  for(var si=1; si<graph.sections.length; si++){
    var sec=graph.sections[si];
    var secNodes=sec.nodes, secWires=sec.wires;
    var activeInSec=secNodes.filter(nd=>nd.fixed||activeKeys.includes(nd.connKey));

    // dim nodes not relevant to this intent
    secNodes.forEach(function(nd){
      if(!nd.fixed&&!activeKeys.includes(nd.connKey)) nodeState(nd.id,'skipped');
    });

    var lastActiveIdx=-1;
    for(var ni=0;ni<secNodes.length;ni++){
      var nd=secNodes[ni];
      if(!nd.fixed&&!activeKeys.includes(nd.connKey)) continue;

      nodeState(nd.id,'active');
      var lk=nodeLookup[nd.id], ld=lk?logLines[lk]:null;
      if(ld){
        var gap=ld.ms/(ld.lines.length+1);
        ld.lines.forEach((ln,li)=>writeLog(ln[0],ln[1],gap*(li+1)));
        await fillNode(nd.id,ld.ms);
      } else { await fillNode(nd.id,600); }
      nodeState(nd.id,'done');

      // light up wires to next active node in same row
      if(lastActiveIdx!==-1){
        for(var wi=lastActiveIdx;wi<ni;wi++){
          if(secWires[wi]) await animHWire(secWires[wi]);
        }
      }
      lastActiveIdx=ni;
      await haltIfPaused(); await sleep(30);
    }

    // vertical wire to next section
    if(si<graph.sections.length-1){
      await animVWire('vw-'+si); await haltIfPaused();
    }
  }

  var tot=stopTimer();
  writeLog('OK','<span style="color:'+C.mint+'">Done</span> — total: <span style="color:'+C.sky+'">'+tot+'s</span>',90);
  if(runLed)sty(runLed,{background:C.tx3,boxShadow:'none',animation:'none'});
  if(logLed)sty(logLed,{background:C.tx3,boxShadow:'none',animation:'none'});
  st.isRunning=false; st.isPaused=false; window._syncPauseBtn&&window._syncPauseBtn();
}

