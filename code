  if(s==='waiting'){
    sty(nd,{opacity:'.35',borderColor:C.bdr,background:C.card,boxShadow:'none'});
    if(gear)sty(gear,{opacity:'0',animation:'none'}); if(chk)sty(chk,{opacity:'0',transform:'scale(.5)'});
    if(fill)fill.style.width='0%';
  } else if(s==='skipped'){
    sty(nd,{opacity:'.12',borderColor:C.bdr,background:C.card,boxShadow:'none'});
  } else if(s==='active'){
    sty(nd,{opacity:'1',borderColor:C.sky,background:'rgba(99,179,237,.05)',boxShadow:'0 0 0 1px rgba(99,179,237,.12),0 0 22px rgba(99,179,237,.08)'});
    if(gear)sty(gear,{opacity:'1',animation:'spin 1.8s linear infinite'});
    if(fill)fill.style.background=C.sky;
  } else if(s==='done'){
    sty(nd,{opacity:'1',borderColor:'rgba(52,211,153,.4)',background:C.card,boxShadow:'0 0 14px rgba(52,211,153,.07)'});
    if(gear)sty(gear,{opacity:'0',animation:'none'});
    if(chk)sty(chk,{opacity:'1',transform:'scale(1)',background:C.mint,color:'#022c22'});
    if(fill){fill.style.background=C.mint;fill.style.width='100%';}
  } else if(s==='frozen'){
    sty(nd,{opacity:'1',borderColor:'rgba(251,191,36,.4)',background:'rgba(251,191,36,.03)',boxShadow:'0 0 14px rgba(251,191,36,.08)'});
