// intent detection 
function guessIntent(txt){
  let t=txt.toLowerCase();
  const g=['hi','hello','hey','thanks','thank you','bye','good morning','good evening','good afternoon','good night','how are you','sup','whats up','cheers','hiya'];
  if(g.some(w=>t.indexOf(w)!==-1))return'chitchat';
  if(/\b(inc|incident|p1|p2|p3|outage|sev\d|major alert)\b/.test(t))return'incident';
  if(/\b(job\b|fail|failed|abort|crash|exit code|stuck|hung|schedule|batch|not running|retry)\b/.test(t))return'job_issue';
  if(/\b(log.*(error|bug)|raise.*(jira|bug|ticket)|create.*jira|track error|file.*bug)\b/.test(t))return'log_error';
  if(/\b(how|sop|workflow|process|steps|explain|guide|procedure|runbook|document|works)\b/.test(t))return'how_to';
  if(/\b(code|deploy|build|release|branch|pull request|merge|ci\/cd|debug|stack trace|null pointer|npm|python|java|git|docker|kubernetes|aws|azure)\b/.test(t))return'dev_help';
  return'general_ops';
}

