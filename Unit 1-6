        <text x="300" y="196" fill="#4f8ef7" font-size="12" text-anchor="middle" font-weight="700">ACCOUNTING</text>
        <text x="300" y="212" fill="#4f8ef7" font-size="12" text-anchor="middle" font-weight="700">CYCLE</text>
        <!-- Step 1: top -->
        <rect x="224" y="10" width="152" height="36" rx="5" fill="#21263a" stroke="#38d9a9" stroke-width="1"/>
        <text x="300" y="28" fill="#38d9a9" font-size="10" text-anchor="middle" font-weight="700">1. Source Documents</text>
        <text x="300" y="41" fill="#8892b0" font-size="9" text-anchor="middle">(Bills, Receipts, Invoices)</text>
        <line x1="300" y1="46" x2="300" y2="138" stroke="#4f8ef7" stroke-width="1.2" marker-end="url(#arrow)"/>
        <!-- Step 2: top-right -->
        <rect x="440" y="50" width="140" height="36" rx="5" fill="#21263a" stroke="#38d9a9" stroke-width="1"/>
        <text x="510" y="68" fill="#38d9a9" font-size="10" text-anchor="middle" font-weight="700">2. Journal Entries</text>
        <text x="510" y="81" fill="#8892b0" font-size="9" text-anchor="middle">(Record transactions)</text>
        <line x1="440" y1="68" x2="365" y2="155" stroke="#4f8ef7" stroke-width="1.2" marker-end="url(#arrow)"/>
        <!-- Step 3: right -->
