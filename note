  <!-- STEP 3 -->
  <div class="step-card">
    <div class="step-card-header">
      <div class="step-num-wrap">
        <div class="step-num">3</div>
        <div class="step-connector"></div>
      </div>
      <div class="step-card-title-area">
        <div class="step-phase-tag tag-setup">Setup</div>
        <div class="step-card-title">Choose the dashboard layout</div>
        <div class="step-card-subtitle">After clicking "Create", Jira asks you to pick a column layout for your dashboard.</div>
      </div>
    </div>
    <div class="step-card-body">

      <div class="action">
        <div class="action-icon-wrap ai-blue">🖼</div>
        <div class="action-content">
          <div class="action-label">What is a layout?</div>
          <div class="action-text">A layout defines <strong>how many columns</strong> of gadgets your dashboard will have. Each gadget (like a chart or list) sits inside a column. More columns = more gadgets visible side by side.</div>
        </div>
      </div>

      <div class="action">
        <div class="action-icon-wrap ai-blue">✅</div>
        <div class="action-content">
          <div class="action-label">Which layout to select</div>
          <div class="action-text">Select <strong>3 Columns</strong>. This is the recommended layout because: Left column = Story count by team member, Center column = Full issue list, Right column = Status &amp; project breakdown. This gives you all 4 gadgets visible without scrolling.</div>
        </div>
      </div>

      <!-- Layout picker -->
      <div class="layout-picker" style="padding: 4px 0;">
        <div class="layout-opt">
