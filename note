FIX 3 — Implement classification as ONE private method:

private bool IsAutomationToolIncident(RemedyIncidentDto incident)
{
    string serviceAccount = GetServiceAccountName();

    // PATH 1 — Submitter matches service account
    // Most reliable — set by API auth, not by user
    // If this matches, it is definitely automation tool
    if (!string.IsNullOrEmpty(incident.Submitter) &&
        incident.Submitter.Equals(serviceAccount,
            StringComparison.OrdinalIgnoreCase))
    {
        return true;
    }

    // PATH 2A — ReportingSource must be "automation"
    // Checked only when PATH 1 failed
    // Users can change this manually so not reliable alone
    if (string.IsNullOrEmpty(incident.ReportingSource) ||
        !incident.ReportingSource.Equals("automation",
            StringComparison.OrdinalIgnoreCase))
    {
        return false;
    }

    // PATH 2B — Notes must contain "Incident details"
    // Checked only when PATH 1 failed and PATH 2A passed
    // Combined with PATH 2A this confirms automation tool
    if (!string.IsNullOrEmpty(incident.Notes) &&
        incident.Notes.Contains("Incident details",
            StringComparison.OrdinalIgnoreCase))
    {
        return true;
    }

    // Nothing matched — it is a FrontDoor incident
    return false;
}

