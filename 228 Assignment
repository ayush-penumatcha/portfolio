<!-- Q8: APRIORI -->
<div id="q8">
<div class="qblock"><div class="qnum">Q8</div><div><div class="qtitle">Apriori Algorithm</div><div class="qsub">Association Rule Mining · Frequent Itemsets · Support &amp; Confidence</div></div><span class="mbadge m6">6 Marks</span></div>
<div class="sec">📖 Concept</div>
<div class="understand"><div class="ul">What it means</div><p>Apriori finds association rules in transaction data — "customers who buy bread and butter also buy milk." It uses two thresholds: minimum Support (how frequently an itemset appears) and minimum Confidence (how reliable the rule is). Example: in a grocery store's transaction dataset, Apriori discovers rules like {bread} → {butter} with 70% confidence.</p></div>
<div class="sec">🔷 Key Terms</div>
<div class="algo">
<strong>Support(A):</strong> Fraction of transactions containing A = count(A) / total_transactions<br>
<strong>Confidence(A→B):</strong> P(B|A) = Support(A∪B) / Support(A)<br>
<strong>Lift(A→B):</strong> Confidence(A→B) / Support(B) — &gt;1 means positive association
</div>
<div class="sec">💻 Python Program</div>
<div class="ans-card"><div class="ans-head"><span>Apriori Algorithm — Grocery Store Transactions</span></div>
<div class="ans-body">
<div class="code"># Apriori Algorithm for Association Rule Mining
# Dataset: Grocery Store Transactions

from itertools import combinations

# Step 1: Transaction Dataset
transactions = [
    ['bread', 'milk', 'butter'],
    ['bread', 'butter'],
    ['milk', 'eggs'],
    ['bread', 'milk', 'eggs'],
    ['butter', 'eggs'],
    ['bread', 'milk'],
    ['milk', 'butter', 'eggs'],
    ['bread', 'butter', 'eggs'],
    ['bread', 'milk', 'butter', 'eggs'],
    ['milk', 'eggs', 'bread']
]

MIN_SUPPORT    = 0.4   # 40% minimum support
MIN_CONFIDENCE = 0.6   # 60% minimum confidence
N = len(transactions)

def get_support(itemset, transactions):
    count = sum(1 for t in transactions if set(itemset).issubset(set(t)))
    return count / len(transactions)

# Step 2: Find frequent 1-itemsets
items = set(item for t in transactions for item in t)
freq_items = {}
print("=== FREQUENT ITEMSETS ===\n")
print("1-Itemsets:")
freq_1 = {}
for item in sorted(items):
    sup = get_support([item], transactions)
    if sup >= MIN_SUPPORT:
        freq_1[frozenset([item])] = sup
        print(f"  {{{item}}}: support = {sup:.2f}")

# Step 3: Find frequent 2-itemsets
print("\n2-Itemsets:")
freq_2 = {}
for itemset in combinations(sorted(items), 2):
    sup = get_support(itemset, transactions)
    if sup >= MIN_SUPPORT:
        freq_2[frozenset(itemset)] = sup
        print(f"  {set(itemset)}: support = {sup:.2f}")

# Step 4: Generate Association Rules from 2-itemsets
print("\n=== ASSOCIATION RULES ===")
print(f"(min_support={MIN_SUPPORT}, min_confidence={MIN_CONFIDENCE})\n")

for itemset, sup in freq_2.items():
    items_list = list(itemset)
    # Try both directions: A→B and B→A
    for i in range(len(items_list)):
        antecedent = frozenset([items_list[i]])
        consequent = itemset - antecedent
        conf = get_support(list(itemset), transactions) / get_support(list(antecedent), transactions)
        lift = conf / get_support(list(consequent), transactions)
        if conf >= MIN_CONFIDENCE:
            print(f"  Rule: {set(antecedent)} → {set(consequent)}")
            print(f"    Support={sup:.2f}, Confidence={conf:.2f}, Lift={lift:.2f}")
            print()</div>
