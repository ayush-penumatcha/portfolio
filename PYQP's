    <table>
      <tr><th>Risk Type</th><th>Description</th><th>Hedging Tool</th></tr>
      <tr><td>Interest Rate Risk</td><td>Rising rates increase cost of floating-rate debt</td><td>Interest Rate Swaps, FRAs</td></tr>
      <tr><td>Foreign Exchange Risk</td><td>Currency fluctuations affect import/export</td><td>Forward contracts, Options</td></tr>
      <tr><td>Liquidity Risk</td><td>Unable to meet short-term obligations</td><td>Cash reserves, credit lines</td></tr>
      <tr><td>Credit Risk</td><td>Customers/counterparties default</td><td>Credit limits, factoring, insurance</td></tr>
